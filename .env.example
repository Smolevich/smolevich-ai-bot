# API keys (override key_file on disk)
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
HF_TOKEN=

# Proxy for providers that need it (Tailscale SOCKS, etc.)
BOT_PROXY_URL=
# Kill switch: set to any non-empty value to ignore BOT_PROXY_URL everywhere.
BOT_PROXY_DISABLED=

# Bot config paths (defaults work on VDS)
# BOT_CONFIG=/etc/socks-monitor/config.json
# BOT_ADMIN_FILE=/etc/socks-monitor/.admin_id
# BOT_DB_FILE=/var/lib/telegram-llm-bot.db
# BOT_SESSIONS_ROOT=/var/lib/smolevich-ai-bot/sessions

# Webhook
# BOT_TUNNEL_URL=https://ai.smolevich.com

# Telegram channel for subscription check
# BOT_REQUIRED_CHANNEL=@naturalists_notes_st

# Benchmark (model-benchmark.py)
# Bearer token for notes-share worker; if empty, --publish steps no-op.
MODEL_LEADERBOARD_TOKEN=
# Kill switch for the daily benchmark pipeline (set to 1 to disable).
BOT_BENCHMARK_DISABLED=
# Override paths if needed (defaults work on VDS once deploy.yml runs).
# BOT_ACPX_LOCK_PATH=/var/lock/acpx.lock
# BOT_ACPX_LOCK_WAIT=30
# BOT_ACPX_ACTIVE_PATH=/run/smolevich-ai-bot-active
# BOT_BENCHMARK_TASKS=/etc/socks-monitor/benchmark-tasks.json
# BOT_BENCHMARK_METHODOLOGY=/etc/socks-monitor/benchmark-tasks.md
# BOT_BENCHMARK_DATASETS=/etc/socks-monitor/benchmark-datasets
# BOT_BENCHMARK_ROOT=/var/lib/smolevich-ai-bot/sessions/benchmarks
# BOT_BENCHMARK_KEEP_FAILED=
