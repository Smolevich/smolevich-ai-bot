# API keys (override key_file on disk)
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=

# Proxy for providers that need it (Tailscale SOCKS, etc.)
BOT_PROXY_URL=
# Kill switch: set to any non-empty value to ignore BOT_PROXY_URL everywhere.
BOT_PROXY_DISABLED=

# Bot config paths (defaults work on VDS)
# BOT_CONFIG=/etc/socks-monitor/config.json
# BOT_ADMIN_FILE=/etc/socks-monitor/.admin_id
# BOT_DB_FILE=/var/lib/telegram-llm-bot.db
# BOT_SESSIONS_ROOT=/var/lib/vds-agent/sessions

# Webhook
# BOT_TUNNEL_URL=https://ai.smolevich.com

# Telegram channel for subscription check
# BOT_REQUIRED_CHANNEL=@naturalists_notes_st
